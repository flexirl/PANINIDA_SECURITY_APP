{
  "expo": {
    "name": "Pan India Security",
    "slug": "pan-india-security",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "panindiasecurity",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3d6d"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Pan India Security needs your location to record attendance check-in pings every 4 hours during your shift.",
          "locationAlwaysPermission": "Pan India Security needs background location access to audit your shift attendance every 4 hours.",
          "locationWhenInUsePermission": "Pan India Security needs your location for geofence-verified attendance check-in.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-task-manager"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.panindiasecurity.app",
      "config": {
        "googleMapsApiKey": "AIzaSyCunS-H02p8puxwEz6xJyAu_Isma0poius"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a3d6d"
      },
      "package": "com.panindiasecurity.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCunS-H02p8puxwEz6xJyAu_Isma0poius"
        }
      }
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "barStyle": "dark-content",
      "backgroundColor": "#00000000"
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#00000000",
      "translucent": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    }
  }
}
