## 7. Database Schema

### 7.1 Core Tables

```sql
-- Users (all roles)
users (
  id UUID PRIMARY KEY,
  name VARCHAR NOT NULL,
  phone VARCHAR UNIQUE NOT NULL,
  role ENUM('admin','manager','recruiter','guard') NOT NULL,
  is_active BOOLEAN DEFAULT true,
  fcm_token TEXT,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Guard Profiles (extends users)
guards (
  id UUID PRIMARY KEY,
  user_id UUID REFERENCES users(id),
  aadhaar_number VARCHAR,
  pan_number VARCHAR,
  address TEXT,
  photo_url TEXT,
  height DECIMAL,
  weight DECIMAL,
  education VARCHAR,
  police_verification BOOLEAN DEFAULT false,
  base_salary DECIMAL NOT NULL,
  joining_date DATE,
  shift_type VARCHAR, -- 'day' | 'night' | 'rotational'
  emergency_contact VARCHAR,
  bank_account VARCHAR,
  bank_ifsc VARCHAR,
  employment_status VARCHAR DEFAULT 'active', -- active | inactive | terminated
  created_at TIMESTAMP DEFAULT NOW()
)

-- Sites
sites (
  id UUID PRIMARY KEY,
  site_name VARCHAR NOT NULL,
  client_name VARCHAR,
  address TEXT,
  latitude DECIMAL NOT NULL,
  longitude DECIMAL NOT NULL,
  geofence_radius INT DEFAULT 100, -- meters
  day_shift_start TIME,
  day_shift_end TIME,
  night_shift_start TIME,
  night_shift_end TIME,
  contact_person VARCHAR,
  contact_phone VARCHAR,
  is_active BOOLEAN DEFAULT true,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Guard-Site Assignments
guard_site_assignments (
  id UUID PRIMARY KEY,
  guard_id UUID REFERENCES guards(id),
  site_id UUID REFERENCES sites(id),
  shift_type VARCHAR NOT NULL, -- 'day' | 'night'
  assigned_date DATE,
  is_active BOOLEAN DEFAULT true
)

-- Attendance
attendance (
  id UUID PRIMARY KEY,
  guard_id UUID REFERENCES guards(id),
  site_id UUID REFERENCES sites(id),
  check_in_time TIMESTAMP,
  check_out_time TIMESTAMP,
  check_in_selfie TEXT,
  check_out_selfie TEXT,
  check_in_lat DECIMAL,
  check_in_lng DECIMAL,
  check_out_lat DECIMAL,
  check_out_lng DECIMAL,
  status VARCHAR DEFAULT 'present', -- present | late | half_day | absent
  is_manual_entry BOOLEAN DEFAULT false,
  remarks TEXT,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Payroll
payroll (
  id UUID PRIMARY KEY,
  guard_id UUID REFERENCES guards(id),
  month VARCHAR NOT NULL, -- '2026-05'
  total_days INT,
  days_present INT,
  base_salary DECIMAL,
  overtime_amount DECIMAL DEFAULT 0,
  penalty_amount DECIMAL DEFAULT 0,
  uniform_deduction DECIMAL DEFAULT 0,
  advance_deduction DECIMAL DEFAULT 0,
  final_salary DECIMAL,
  status VARCHAR DEFAULT 'draft', -- draft | generated | approved
  generated_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Uniform Tracking
uniforms (
  id UUID PRIMARY KEY,
  guard_id UUID REFERENCES guards(id),
  item_name VARCHAR NOT NULL,
  item_cost DECIMAL,
  issued_date DATE,
  payment_status VARCHAR DEFAULT 'pending', -- pending | partial | paid | deducted
  amount_paid DECIMAL DEFAULT 0,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Candidates (Recruitment)
candidates (
  id UUID PRIMARY KEY,
  name VARCHAR NOT NULL,
  phone VARCHAR NOT NULL,
  height DECIMAL,
  weight DECIMAL,
  education VARCHAR,
  experience_years INT,
  preferred_location VARCHAR,
  salary_expectation DECIMAL,
  availability_date DATE,
  status VARCHAR DEFAULT 'new',
  recruiter_id UUID REFERENCES users(id),
  notes TEXT,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Inspections
inspections (
  id UUID PRIMARY KEY,
  site_id UUID REFERENCES sites(id),
  inspector_id UUID REFERENCES users(id),
  inspection_date TIMESTAMP DEFAULT NOW(),
  guards_present TEXT[], -- array of guard IDs verified
  guards_absent TEXT[],
  photos TEXT[], -- array of photo URLs
  remarks TEXT,
  incident_reported BOOLEAN DEFAULT false,
  incident_severity VARCHAR, -- low | medium | high | critical
  incident_description TEXT,
  latitude DECIMAL,
  longitude DECIMAL,
  created_at TIMESTAMP DEFAULT NOW()
)

-- Notifications
notifications (
  id UUID PRIMARY KEY,
  user_id UUID REFERENCES users(id),
  title VARCHAR NOT NULL,
  body TEXT,
  type VARCHAR, -- shift_reminder | attendance | salary | inspection
  is_read BOOLEAN DEFAULT false,
  created_at TIMESTAMP DEFAULT NOW()
)
```

